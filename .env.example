# --- Server ---
PORT=6736

# Set when behind a reverse proxy. "1" trusts a single proxy hop (Cloudflare,
# nginx, Caddy in front). Use "false" to disable, or a number for multiple hops.
TRUST_PROXY=1

# --- Public URL ---
# The URL where this instance is reachable. Used in meta tags, canonical URL,
# OG image URLs on the landing page.
PUBLIC_URL=http://localhost:6736

# --- Branding (all optional) ---
SITE_NAME=OpenGraph Resizer
SITE_TAGLINE=Resize images for social media & analyze any URL's OpenGraph tags
# BRAND_NAME shows in the footer ("A Product by ..."). Leave empty to hide.
BRAND_NAME=
BRAND_URL=

# --- Analytics (optional) ---
# When unset, no Google Analytics scripts are injected and the CSP does not
# whitelist GA hosts. Set to your GA4 measurement ID to enable.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Limits ---
MAX_UPLOAD_MB=10
RATE_LIMIT_GENERATE=20
RATE_LIMIT_ANALYZE=30

# --- CORS ---
# Comma-separated list of allowed origins, or "*" to allow all.
ALLOWED_ORIGINS=*
